><action
>يبدأ لعبة جديدة.</action
></para>
</listitem>
</varlistentry>

<varlistentry id="game-end">
<term
><menuchoice
><shortcut
><keycombo action="simul"
>&Ctrl;&End;</keycombo
> </shortcut
> <guimenu
>لعبة</guimenu
> <guimenuitem
