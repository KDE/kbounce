<title
>عناصر القائمة</title>

<sect2>
<title
>قائمة اللعبة</title>

<variablelist>
<varlistentry id="game-new">
<term
><menuchoice
><shortcut
><keycombo action="simul"
>&Ctrl;<keycap
>N</keycap
></keycombo
> </shortcut
> <guimenu
>لعبة</guimenu
> <guimenuitem
>جديد</guimenuitem
> </menuchoice
></term>
<listitem>
